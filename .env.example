PORT=5000
MONGO_URI=mongodb://localhost:27017/gema_v2
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret
REFRESH_TOKEN_SECRET=replace_with_another_long_random_secret
REFRESH_TOKEN_EXPIRES=7d
AUDIT_LOG_SIGNING_KEY=replace_with_a_dedicated_audit_hmac_key
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=120
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=40
DEV_IP_WHITELIST=127.0.0.1,::1,192.168.1.10
BYPASS_SECURITY=false
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_with_strong_password
ADMIN_NAME=GEMA_Admin
SITE_BASE_URL=http://localhost:5000
BACKUP_DIR=backend/backups
BACKUP_WEBHOOK_URL=
